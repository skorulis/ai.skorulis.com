---
const { title = "Learning AI – Blog" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content="Notes and experiments from my journey learning AI."
    />
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a href="/" class="logo">Learning AI</a>
        <nav class="nav">
          <a href="/">Home</a>
        </nav>
      </header>
      <slot />
      <footer class="site-footer">
        <p>© {new Date().getFullYear()} Learning AI.</p>
      </footer>
    </div>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "SF Pro Text",
      sans-serif;
    background: #f5f5f8;
    color: #111827;
  }

  .shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 960px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem 0.5rem;
  }

  .logo {
    font-weight: 650;
    letter-spacing: -0.02em;
    text-decoration: none;
    color: inherit;
  }

  .nav a {
    text-decoration: none;
    margin-left: 1rem;
    color: #4b5563;
    font-size: 0.95rem;
  }

  .nav a:hover {
    color: #111827;
  }

  .site-footer {
    margin-top: auto;
    padding: 1.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: #6b7280;
  }
</style>

